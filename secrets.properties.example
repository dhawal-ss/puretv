# Copy this file to `secrets.properties` and fill in your own value.
# `secrets.properties` is gitignored and injected into the build at compile time
# (see core/build.gradle.kts → generateTwitchSecrets). CI uses the
# TWITCH_CLIENT_SECRET environment variable instead.
#
# Generate a secret at https://dev.twitch.tv/console/apps → Manage → New Secret.
twitch.client.secret=PASTE_YOUR_CLIENT_SECRET_HERE
