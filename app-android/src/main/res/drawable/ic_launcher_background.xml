<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon BACKGROUND. A near-black field with a soft off-center purple
  glow (radial gradient) so the foreground mark reads as lit from within rather
  than pasted onto flat color. Full 108x108 canvas: the launcher masks it.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0 h108 v108 h-108 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="42"
                android:centerY="40"
                android:gradientRadius="78"
                android:startColor="#FF221033"
                android:centerColor="#FF130A1E"
                android:endColor="#FF0A0A0F" />
        </aapt:attr>
    </path>
</vector>
