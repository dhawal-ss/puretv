<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose owns all rendering; this just sets the window background to
         PureTVColors.Background (0xFF0A0A0F) so there's no white flash on launch. -->
    <style name="Theme.PureTv" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
