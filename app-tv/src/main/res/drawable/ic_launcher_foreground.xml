<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon FOREGROUND. The PureTV mark: a shield (ad-free protection)
  carrying a play triangle (live streaming) with a small check notch on the
  shield (verified-clean). Drawn inside the 66x66dp safe zone (x,y roughly
  21..87 of the 108 canvas) so no part is clipped by any launcher mask. Brand
  purple gradient 0xFF9B5DE5 -> 0xFFC77DFF; the play glyph is near-white for
  contrast against the purple. Shared 1:1 with the phone app so the two builds
  carry the same brand mark.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Shield body: rounded top shoulders tapering to a point at the bottom. -->
    <path
        android:pathData="M54,25
            C61,30 70,32 78,32
            L78,54
            C78,69 68,79 54,85
            C40,79 30,69 30,54
            L30,32
            C38,32 47,30 54,25 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="32"
                android:startY="28"
                android:endX="76"
                android:endY="84"
                android:startColor="#FF9B5DE5"
                android:endColor="#FFC77DFF" />
        </aapt:attr>
    </path>

    <!-- Soft inner highlight rim so the shield has a touch of dimension. -->
    <path
        android:pathData="M54,31
            C60,35 67,37 73,37
            L73,54
            C73,66 65,74 54,79
            C43,74 35,66 35,54
            L35,37
            C41,37 48,35 54,31 Z"
        android:fillColor="#22FFFFFF" />

    <!-- Play triangle, near-white, centered in the shield. -->
    <path
        android:pathData="M48,45
            L66,55
            L48,65 Z"
        android:fillColor="#FFF7F2FF" />

    <!-- Check notch on the lower-right of the shield: verified, ad-free clean. -->
    <path
        android:pathData="M61,68
            L65,72
            L73,63"
        android:strokeColor="#FFF7F2FF"
        android:strokeWidth="3.2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>
