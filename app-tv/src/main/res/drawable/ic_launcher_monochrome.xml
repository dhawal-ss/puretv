        android:fillColor="#FFFFFFFF"
        android:fillType="evenOdd"
        android:pathData="M54,25
            C61,30 70,32 78,32
            L78,54
            C78,69 68,79 54,85
            C40,79 30,69 30,54
            L30,32
            C38,32 47,30 54,25 Z
