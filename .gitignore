# Gradle
.gradle/
build/
**/build/

# IDE
.idea/
*.iml

# Android SDK location (machine-specific, never commit)
local.properties

# Kotlin / JVM
*.class
*.jar
# …but DO commit the Gradle wrapper jar (needed by ./gradlew in CI & for contributors)
!gradle/wrapper/gradle-wrapper.jar

# Bundled VLC native libraries (populated by `gradle :app-windows:bundleVlc`).
# These are large binary files (~95 MB) — run bundleVlc on each build machine
# before packaging. See app-windows/build.gradle.kts `bundleVlc` task.
app-windows/resources/windows/vlc/

# Bundled mpv native library (populated by `gradle :app-windows:bundleMpv`).
# Large binary (~120 MB libmpv-2.dll) — run bundleMpv on each build machine.
# The Anime4K shader source lives (committed) in app-windows/shaders/.
app-windows/resources/windows/mpv/

# Secrets — injected at build time, never committed (see secrets.properties.example)
secrets.properties

# Private keys — NEVER commit. The Ed25519 update-signing key (and any other
# *.pem) must be generated OUTSIDE the repo (see UpdateSigning.kt).
*.pem

# Android release signing — NEVER commit. The keystore + its credentials sign
# the release APK; losing them means future updates can't install over an
# installed build. Back them up somewhere safe outside the repo.
*.jks
*.keystore
keystore.properties

# Internal build/design docs (specs, plans, prompts) — kept out of the repo.
docs/superpowers/

# Visual-brainstorm companion scratch (mockups, server state) — local only.
.superpowers/

# Local-only token store + key material written by DesktopSettingsStore at runtime.
tokens.enc
.keyseed

# Build / run / audit logs and tool scratch — never source.
*.log
.playwright-mcp/

# OS
.DS_Store
Thumbs.db
